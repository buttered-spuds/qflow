{
  "name": "@qflow/core",
  "version": "0.2.2",
  "description": "Core agents, runner adapters, LLM adapters and notification adapters for the qflow testing framework",
  "keywords": ["testing", "playwright", "pytest", "jest", "ai", "llm", "jira", "azure-devops", "ci", "automation"],
  "license": "MIT",
  "author": "barrymadine",
  "homepage": "https://github.com/buttered-spuds/qflow#readme",
  "repository": {
    "type": "git",
